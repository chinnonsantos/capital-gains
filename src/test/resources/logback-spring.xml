<configuration>
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/test-${APP_NAME:-capital-gains}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- daily rollover and up to 10MB per file -->
            <fileNamePattern>./logs/bkp-test-${APP_NAME:-capital-gains}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>10</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS O} %-5level [%thread] %M\(%F:%L\) - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL_ROOT:-DEBUG}">
        <appender-ref ref="FILE" />
    </root>
</configuration>
